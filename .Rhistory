#| include: false
#| echo: false
#| label: tbl-var
#| tbl-cap: Variables Used in the Analysis
# This table presents the variables that we ultimately used for the analysis.But it's too much. So we decided to not show it in the report, instead we use "Feature Selection Summary" to explain this part.
var_table <- data.frame(
Variable = c(
"y",
"age","job","marital","education","housing","loan",
"contact","month","day_of_week",
"campaign","pdays_contact","previous","poutcome",
"cons.price.idx","cons.conf.idx","euribor3m"
),
Type = c(
"Categorical",
"Numeric","Categorical","Categorical","Categorical","Categorical","Categorical",
"Categorical","Categorical","Categorical",
"Numeric","Categorical","Numeric","Categorical",
"Numeric","Numeric","Numeric"
),
Description = c(
"Term deposit subscription (yes/no)",
"Client age",
"Job type",
"Marital status",
"Education level",
"Housing loan status",
"Personal loan status",
"Contact type",
"Last contact month",
"Last contact weekday",
"Number of contacts in current campaign",
"Whether previously contacted",
"Number of previous contacts",
"Previous campaign outcome",
"Consumer price index",
"Consumer confidence index",
"Euribor 3-month rate"
)
)
# use gt() to better show the selected variable
var_table %>%
gt() %>%
tab_header(
title = "Variables Used in the Analysis",
subtitle = "Selected variables from the Bank Marketing dataset"
)  %>% # add title and subtitle
cols_label(
Variable = "Variable",
Type = "Type",
Description = "Description")#change the column label
