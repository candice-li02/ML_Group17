# load the libraries we will use.
packages <-c("skimr",
"corrplot",
"rpart",
"gt",
"dplyr",
"ggplot2",
"gridExtra",
"caret",
"rpart.plot",
"randomForest",
"caret",
"pROC",
"ROCR",
"MASS"
)
# Library packages
for(pkg in packages){
library(pkg, character.only = TRUE)
}
